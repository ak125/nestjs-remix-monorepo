{
  "_comment": "Règles préservées 1:1 de @remix-run/eslint-config@2.17.5 (retiré en PR-9h F/C0). Source de vérité figée pour zéro drift de lint vs legacy. Clés consommées par eslint.config.js : base, typescript, settingsReact. Les settings import (resolvers/parsers) sont re-dérivés inline dans eslint.config.js (le snapshot @remix-run contenait des chemins absolus non portables).",
  "base": {
    "array-callback-return": 1,
    "getter-return": 1,
    "new-parens": 1,
    "no-array-constructor": 1,
    "no-caller": 2,
    "no-cond-assign": [
      1,
      "except-parens"
    ],
    "no-const-assign": 2,
    "no-control-regex": 1,
    "no-dupe-args": 1,
    "no-dupe-class-members": 1,
    "no-dupe-keys": 1,
    "no-duplicate-case": 1,
    "no-empty-character-class": 1,
    "no-empty-pattern": 1,
    "no-empty": [
      1,
      {
        "allowEmptyCatch": true
      }
    ],
    "no-eval": 2,
    "no-ex-assign": 1,
    "no-extend-native": 1,
    "no-extra-bind": 1,
    "no-extra-label": 1,
    "no-extra-boolean-cast": 1,
    "no-func-assign": 2,
    "no-global-assign": 2,
    "no-implied-eval": 1,
    "no-invalid-regexp": 1,
    "no-label-var": 1,
    "no-labels": [
      1,
      {
        "allowLoop": true,
        "allowSwitch": false
      }
    ],
    "no-lone-blocks": 1,
    "no-loop-func": 1,
    "no-mixed-operators": [
