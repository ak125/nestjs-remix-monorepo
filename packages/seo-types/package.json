{
  "name": "@repo/seo-types",
  "version": "1.0.0",
  "description": "Shared SEO types and Zod schemas for the SEO department modules (Observability, On-page, Content ops, Intelligence, GEO/AEO).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./observability": {
      "types": "./dist/observability.d.ts",
      "import": "./dist/observability.js",
      "require": "./dist/observability.js"
    },
    "./onpage": {
      "types": "./dist/onpage.d.ts",
      "import": "./dist/onpage.js",
      "require": "./dist/onpage.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence.d.ts",
      "import": "./dist/intelligence.js",
      "require": "./dist/intelligence.js"
    },
    "./geo-aeo": {
      "types": "./dist/geo-aeo.d.ts",
      "import": "./dist/geo-aeo.js",
      "require": "./dist/geo-aeo.js"
    },
    "./content-ops": {
      "types": "./dist/content-ops.d.ts",
      "import": "./dist/content-ops.js",
      "require": "./dist/content-ops.js"
    },
    "./crux": {
      "types": "./dist/crux.d.ts",
      "import": "./dist/crux.js",
      "require": "./dist/crux.js"
    },
    "./control-dashboard": {
      "types": "./dist/control-dashboard.d.ts",
      "import": "./dist/control-dashboard.js",
      "require": "./dist/control-dashboard.js"
    },
    "./control-dashboard.rules": {
      "types": "./dist/control-dashboard.rules.d.ts",
      "import": "./dist/control-dashboard.rules.js",
      "require": "./dist/control-dashboard.rules.js"
    },
    "./vehicle-aware-label": {
      "types": "./dist/vehicle-aware-label.d.ts",
      "import": "./dist/vehicle-aware-label.js",
      "require": "./dist/vehicle-aware-label.js"
    },
    "./seo-variations": {
      "types": "./dist/seo-variations.d.ts",
      "import": "./dist/seo-variations.js",
      "require": "./dist/seo-variations.js"
    },
    "./build-r2-h1": {
      "types": "./dist/build-r2-h1.d.ts",
      "import": "./dist/build-r2-h1.js",
      "require": "./dist/build-r2-h1.js"
    },
    "./build-r8-h1": {
      "types": "./dist/build-r8-h1.d.ts",
      "import": "./dist/build-r8-h1.js",
      "require": "./dist/build-r8-h1.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
