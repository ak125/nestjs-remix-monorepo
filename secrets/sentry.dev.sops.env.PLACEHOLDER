# PLACEHOLDER — to be replaced post-merge by the real encrypted file.
#
# Why this placeholder exists:
#   The encrypted `secrets/sentry.dev.sops.env` cannot be created until the
#   age public keys (owner + dev_vps) are filled into `.sops.yaml`. That step
#   requires a human running `age-keygen` on their workstation and on the VPS
#   — see `docs/runbooks/secrets-sops.md` § Bootstrap.
#
# Once bootstrap is done, run:
#
#   cat > /tmp/sentry.env <<'EOF'
#   SENTRY_DSN=https://78d046f8...4511342994784336
#   VITE_SENTRY_DSN=https://b236f551...4511343000223824
#   SENTRY_AUTH_TOKEN=sntryu_...
#   SENTRY_ORG=auto-pieces-equipement
#   SENTRY_PROJECT_BACKEND=automecanik-backend-dev
#   SENTRY_PROJECT_FRONTEND=automecanik-frontend-dev
#   SENTRY_ENVIRONMENT=dev
#   EOF
#
#   sops encrypt /tmp/sentry.env > secrets/sentry.dev.sops.env
#   shred -u /tmp/sentry.env
#   git rm secrets/sentry.dev.sops.env.PLACEHOLDER
#   git add .sops.yaml secrets/sentry.dev.sops.env
#   git commit -s -m 'chore(secrets): bootstrap sentry.dev.sops.env'
#
# CI guard `scripts/secrets/check-no-plaintext.sh` will fail if any
# `secrets/*.env` (without `.sops.` infix) is committed.
