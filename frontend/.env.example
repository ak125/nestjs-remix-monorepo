# API Configuration
VITE_API_URL=http://localhost:3000

# 🚀 Performance Features
# Active l'endpoint RPC V2 ultra-optimisé (75ms vs 680ms)
# Si désactivé ou en cas d'erreur, fallback automatique sur méthode classique
# Valeurs: true (défaut) | false
ENABLE_RPC_V2=true

# Storage URLs
VITE_SUPABASE_STORAGE_URL=https://cxpojprgwgubzjyqzmoq.supabase.co/storage/v1/object/public

# Sentry (frontend / Remix browser SDK)
# DSN is exposed to the browser at runtime via window.ENV (root.tsx loader).
# Same image runs DEV/PROD with different DSN read at request time.
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
