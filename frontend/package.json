{
  "name": "@fafa/frontend",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "./index.cjs",
  "types": "./index.d.cts",
  "scripts": {
    "build": "react-router build",
    "size": "size-limit",
    "dev": "echo 'Frontend dev handled by backend startDevServer on :3000'",
    "old-dev": "remix vite:dev",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test:a11y": "playwright test tests/a11y --project=chromium",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:visual:update": "playwright test tests/visual --project=chromium --update-snapshots",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:qa": "npm run test:a11y && npm run test:visual",
    "design:detect": "impeccable detect --fast app",
    "design:detect:json": "impeccable detect --fast --json app"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "eslint --cache --fix --max-warnings=0",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fafa/design-tokens": "^1.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/express": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "@repo/cwv-taxonomy": "*",
    "@repo/database-types": "*",
    "@repo/registry": "*",
    "@repo/seo-roles": "*",
    "@repo/seo-types": "*",
    "@repo/seo-url-contract": "*",
    "@sentry/react-router": "^10.51.0",
    "@tanstack/react-query": "^5.87.1",
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-italic": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^0.7.2",
    "embla-carousel-react": "^8.6.0",
    "html-react-parser": "^5.2.10",
    "isbot": "^4.1.0",
    "isomorphic-dompurify": "^2.35.0",
    "lucide-react": "^0.462.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.62.0",
    "react-router": "^7.15.0",
    "recharts": "^2.15.4",
    "remix-flat-routes": "^0.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^4.1.1",
    "@fafa/eslint-config": "*",
    "@fafa/typescript-config": "*",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.15.0",
    "@react-router/remix-routes-option-adapter": "^7.15.0",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^9.1.13",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-onboarding": "^9.1.20",
    "@storybook/addon-vitest": "^9.1.13",
    "@storybook/react-vite": "^9.1.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
