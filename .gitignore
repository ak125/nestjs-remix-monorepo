# =========================
# ENV / SECRETS (NEVER COMMIT)
# =========================
.env
.env.*
backend/.env*
frontend/.env*

# MCP configuration (contains tokens)
.mcp.json
.mcp/

# allow templates/examples only
!**/.env.example
!**/.env.template
!**/.env.sample

# Secrets and credentials
*.pem
*.key
*.cert
*.p12
*-credentials.json
*-serviceaccount.json

# SOPS-encrypted env files in secrets/ are committed; plain .env there is not.
# (These re-enable .env.* matching the SOPS naming convention.)
!secrets/*.sops.env
!secrets/README.md
# age private keys must NEVER be committed
secrets/*.key
secrets/*.txt

# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
out/

# Redis snapshots (ne jamais versionner)
dump.rdb
cache/dump.rdb
cache/*.rdb
cache/temp-*.rdb

# Vite timestamped config artifacts (ne jamais versionner)
frontend/vite.config.ts.timestamp-*

# AI Agents - Python System (local only, ne jamais versionner)
ai-agents-python/
ai-agents-python/**/*.json
ai-agents-python/**/*.log
ai-agents-python/.temp/
ai-agents-python/__pycache__/
ai-agents-python/**/__pycache__/
ai-agents-python/*.pyc
ai-agents-python/**/*.pyc



