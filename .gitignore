tests-curl/.cookies

# Deep-audit cache (PR-0a) — big & churny, regenerated via `npm run audit:inventory`.
# The curated artefacts (audit/*.json, audit/*.md) ARE versioned.
audit/cache/

# ============================================
# Large files protection (2026-03-16)
# GitHub rejects >100MB, warns >50MB
# ============================================
*.7z
.spec/reports/*_audit_*.md
.github/*.xlsx
.github/*.sql
.github/*.7z
.github/*.pdf
.github/*.CMD

# Repository Control Plane (ADR-058) — PR-C
# audit/registry/cache/ is per-script transient cache, jetable
audit/registry/cache/
# audit/registry/planning.json is a time-varying PR snapshot (meta.generatedAt
# changes every run) — generated fresh in CI/runtime, never committed (would churn
# + break registry-fresh diff). The 5 code-projection registries stay committed.
audit/registry/planning.json
# audit/registry/dependency-graph.json — same nature (time-varying PR-stack
# snapshot derived from planning.json), generated fresh, never committed.
audit/registry/dependency-graph.json
# audit/registry/automation.json — Layer 1 automation inventory (build-automation-inventory.js)
# Time-varying snapshot, regenerated on demand ; L2 overlay `automation-reality.yaml` is SoT.
audit/registry/automation.json

# Architecture contract (PR-2) — JSON Schema mirror is ephemeral, regenerated by
# `npm run architecture:build` on every run. Not committed to avoid PR noise /
# merge conflicts. Fresh checkouts: run the build once for IDE $schema resolution.
.spec/00-canon/_schema/architecture.schema.json
.spec/00-canon/_schema/db.schema.json
.spec/00-canon/_schema/runtime-topology.schema.json
.spec/00-canon/_schema/dep-governance.schema.json
.spec/00-canon/_schema/rpc.schema.json

# CI gate report artifacts (written by scripts/ci/*-gate.mjs, never committed)
dod-gate-report.md

# G10 EXPLORATION_BUDGET probes (ADR-081) — local deps + tsbuildinfo, never committed
scripts/research/node_modules/
scripts/research/*.tsbuildinfo
