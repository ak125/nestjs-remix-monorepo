{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automecanik.com/schemas/page-contract-r4.media-slots.schema.json",
  "title": "PageContractR4 + MediaSlots",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "entity", "page_role", "intents", "headings", "sections", "media_slots", "forbidden", "validation"],
  "properties": {
    "contract_version": { "type": "string", "pattern": "^R4\\.[0-9]+\\.[0-9]+$" },
    "page_role": { "const": "R4_REFERENCE" },

    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "short_title", "system"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "short_title": { "type": "string", "minLength": 1 },
        "system": { "type": "string", "minLength": 1 },
        "variants": { "type": "array", "items": { "type": "string" }, "default": [] },
        "related_entities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slug", "title"],
            "properties": {
              "slug": { "type": "string" },
              "title": { "type": "string" },
              "relation": { "type": "string", "enum": ["interaction", "confusion", "system", "related"] }
            }
          },
          "default": []
        }
      }
    },

    "intents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "label", "user_need"],
          "properties": {
            "role": { "const": "R4" },
            "label": { "type": "string", "minLength": 1 },
            "user_need": { "type": "string", "minLength": 1 }
          }
        },
        "secondary": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label"],
            "properties": {
              "label": { "type": "string" },
              "allowed": { "type": "boolean", "default": true }
            }
          },
          "default": []
        }
      }
    },

    "headings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["h1", "sections"],
      "properties": {
        "h1": { "type": "string", "minLength": 1 },
        "sections": {
          "type": "array",
          "minItems": 7,
          "maxItems": 9,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "h2"],
            "properties": {
              "id": {
                "type": "string",
                "enum": [
                  "definition",
                  "takeaways",
                  "role_mecanique",
                  "composition",
                  "variants",
                  "key_specs",
                  "faq",
                  "does_not",
                  "rules",
                  "scope"
                ]
              },
              "h2": { "type": "string", "minLength": 1 },
              "h3": { "type": "array", "items": { "type": "string" }, "maxItems": 3, "default": [] }
            }
          }
        }
      }
    },

    "sections": {
      "type": "array",
      "minItems": 7,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "h2", "content_blocks", "keywords"],
        "properties": {
          "section_id": {
            "type": "string",
            "enum": [
              "definition",
              "takeaways",
              "role_mecanique",
              "composition",
              "variants",
              "key_specs",
              "faq",
              "does_not",
              "rules",
              "scope"
            ]
          },
          "h2": { "type": "string", "minLength": 1 },

          "content_blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "text"],
                  "properties": {
                    "type": { "const": "paragraph" },
                    "text": { "type": "string", "minLength": 10 }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "items"],
                  "properties": {
                    "type": { "const": "bullets" },
                    "items": { "type": "array", "minItems": 2, "maxItems": 12, "items": { "type": "string", "minLength": 6 } }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "items"],
                  "properties": {
                    "type": { "const": "numbered" },
                    "items": { "type": "array", "minItems": 3, "maxItems": 12, "items": { "type": "string", "minLength": 6 } }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "items"],
                  "properties": {
                    "type": { "const": "cards" },
                    "items": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 8,
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["title", "text"],
                        "properties": {
                          "title": { "type": "string", "minLength": 2 },
                          "text": { "type": "string", "minLength": 20 }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "columns", "rows"],
                  "properties": {
                    "type": { "const": "table" },
                    "columns": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "type": "string" } },
                    "rows": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 12,
                      "items": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "type": "string" } }
                    },
                    "note": { "type": "string" }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "items"],
                  "properties": {
                    "type": { "const": "faq" },
                    "items": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 10,
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["q", "a"],
                        "properties": {
                          "q": { "type": "string", "minLength": 8 },
                          "a": { "type": "string", "minLength": 25 }
                        }
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "tone", "title", "text"],
                  "properties": {
                    "type": { "const": "callout" },
                    "tone": { "type": "string", "enum": ["indigo", "green", "blue", "amber", "red", "purple", "slate"] },
                    "icon": { "type": "string" },
                    "title": { "type": "string", "minLength": 2 },
                    "text": { "type": "string", "minLength": 10 }
                  }
                }
              ]
            }
          },

          "keywords": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_keywords", "supporting_terms", "forbidden_terms"],
            "properties": {
              "target_keywords": { "type": "array", "minItems": 6, "maxItems": 12, "items": { "type": "string" } },
              "supporting_terms": { "type": "array", "minItems": 10, "maxItems": 24, "items": { "type": "string" } },
              "forbidden_terms": {
                "type": "array",
                "minItems": 8,
                "maxItems": 30,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["term", "reason", "target_role"],
                  "properties": {
                    "term": { "type": "string", "minLength": 2 },
                    "reason": { "type": "string", "minLength": 5 },
                    "target_role": { "type": "string", "enum": ["R1", "R3", "R5"] }
                  }
                }
              }
            }
          }
        }
      }
    },

    "media_slots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hero", "by_section"],
      "properties": {
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "variant", "alt", "goal"],
          "properties": {
            "type": { "type": "string", "enum": ["image", "diagram", "none"] },
            "variant": { "type": "string", "enum": ["photo_piece", "diagram_simple", "exploded_view", "og_template", "none"] },
            "goal": { "type": "string", "enum": ["comprehension", "trust", "scanability", "disambiguation", "snippet_support"] },
            "alt": { "type": "string", "minLength": 10 },
            "image_brief": {
              "type": "object",
              "additionalProperties": false,
              "required": ["prompt", "avoid"],
              "properties": {
                "prompt": { "type": "string", "minLength": 20 },
                "avoid": { "type": "array", "minItems": 3, "items": { "type": "string" } }
              }
            }
          }
        },
        "by_section": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "definition": { "$ref": "#/$defs/mediaSlot" },
            "takeaways": { "$ref": "#/$defs/mediaSlot" },
            "role_mecanique": { "$ref": "#/$defs/mediaSlot" },
            "composition": { "$ref": "#/$defs/mediaSlot" },
            "variants": { "$ref": "#/$defs/mediaSlot" },
            "key_specs": { "$ref": "#/$defs/mediaSlot" },
            "faq": { "$ref": "#/$defs/mediaSlot" },
            "does_not": { "$ref": "#/$defs/mediaSlot" },
            "rules": { "$ref": "#/$defs/mediaSlot" },
            "scope": { "$ref": "#/$defs/mediaSlot" }
          }
        },
        "sidebar": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "product_thumb": { "$ref": "#/$defs/mediaSlot" }
          }
        }
      }
    },

    "forbidden": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lexicons"],
      "properties": {
        "lexicons": {
          "type": "object",
          "additionalProperties": false,
          "required": ["R1", "R3", "R5"],
          "properties": {
            "R1": { "type": "array", "items": { "type": "string" } },
            "R3": { "type": "array", "items": { "type": "string" } },
            "R5": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hard_gates"],
      "properties": {
        "hard_gates": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "enum": [
              "NO_HOWTO_FOCUS_IN_R4",
              "NO_TRANSACTIONAL_FOCUS_IN_R4",
              "NO_DIAGNOSTIC_FOCUS_IN_R4",
              "NO_DUPLICATE_SECTIONS",
              "R4_SECTIONS_COUNT_OK",
              "MEDIA_SLOTS_PRESENT",
              "CANONICAL_ORIGIN_UNIFIED"
            ]
          }
        },
        "notes": { "type": "string" }
      }
    }
  },

  "$defs": {
    "mediaSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "goal"],
      "properties": {
        "type": { "type": "string", "enum": ["none", "image", "diagram", "table", "callout"] },
        "variant": {
          "type": "string",
          "enum": [
            "photo_piece",
            "diagram_simple",
            "exploded_view",
            "mini_icon",
            "comparison_table",
            "specs_table",
            "callout_policy",
            "callout_scope",
            "none"
          ],
          "default": "none"
        },
        "goal": { "type": "string", "enum": ["comprehension", "trust", "scanability", "disambiguation", "snippet_support"] },
        "alt": { "type": "string" },
        "image_brief": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "prompt": { "type": "string" },
            "avoid": { "type": "array", "items": { "type": "string" } }
          }
        },
        "table_schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "columns": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 6 },
            "row_templates": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 8 },
            "note": { "type": "string" }
          }
        }
      }
    }
  }
}
