  "section_claim_limits": {
    "_comment": "Nombre max de claims numériques/factuelles par section × rôle. Sections/rôles absents = pas de limite explicite (défaut runtime legacy : 99).",
    "default_when_unlisted": 99,
    "limits": {
      "intro_role": { "R3_guide": 3, "R1": 1, "R3_conseils": 2, "R4": 1 },
      "risk": { "R3_guide": 5, "R1": 2 },
      "timing": { "R3_guide": 3, "R3_conseils": 2 },
      "how_to_choose": { "R3_guide": 4, "R3_conseils": 2 },
      "costs": { "R5": 4, "R3_conseils": 2 },
      "faq": { "R3_guide": 6, "R3_conseils": 4, "R1": 3, "R5": 3 },
      "symptoms": { "R5": 5 },
      "composition": { "R4": 4 }
    }
  },

  "gate_c_similarity_budgets": {
    "_comment": "Gate C (similarité sémantique TF-IDF, cosine) — budgets cross-rôle par paire. Seuils warn/fail sur le cosine global du contenu + seuils par section (paire R1↔R3 uniquement dans le legacy). 'default' = budget appliqué à toute paire non listée (fallback legacy brief-gates.service.ts).",
    "pairs": {
      "R1↔R3": {
        "global_threshold": { "warn": 0.7, "fail": 0.8 },
        "max_sections_above_warn": 1,
        "per_section_thresholds": {
          "intro_role": { "warn": 0.8, "fail": 0.9 },
          "faq": { "warn": 0.6, "fail": 0.75 },
          "symptoms": { "warn": 0.5, "fail": 0.7 },
          "how_to_choose": { "warn": 0.55, "fail": 0.7 },
          "timing": { "warn": 0.7, "fail": 0.85 }
        }
      },
      "R1↔R4": {
        "global_threshold": { "warn": 0.6, "fail": 0.75 },
        "max_sections_above_warn": 1,
        "per_section_thresholds": {}
      },
      "R3↔R4": {
        "global_threshold": { "warn": 0.65, "fail": 0.8 },
        "max_sections_above_warn": 1,
        "per_section_thresholds": {}
      }
    },
    "default": {
      "global_threshold": { "warn": 0.75, "fail": 0.85 },
      "max_sections_above_warn": 1,
      "per_section_thresholds": {}
    }
  },

  "role_forbidden_patterns": {
    "_comment": "Gate A (role compliance) — regex (source + flags + raison) détectant du contenu hors-rôle dans une page. Valeurs concrètes NON couvertes par les ban_*/forbidden_terms des page-contracts (ceux-ci définissent la FORME des instances, pas ces valeurs). Verdict legacy : >= fail_at_hits patterns matchés = FAIL, >= warn_at_hits = WARN.",
    "verdict_rule": { "fail_at_hits": 3, "warn_at_hits": 1 },
    "R1": [
      { "pattern": "étape\\s+[0-9]", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "étape\\s+(un|deux|trois|quatre|cinq)", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "outils?\\s+nécessaires?", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "couple\\s+de\\s+serrage", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "\\b(démonter|déposer|reposer|remonter)\\b", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "\\b(tutoriel|tuto|pas[\\s-]à[\\s-]pas)\\b", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "\\b(définition|glossaire|encyclopédie)\\b", "flags": "i", "reason": "Reference = R4" }
    ],
    "R3_guide": [
      { "pattern": "ajouter\\s+au\\s+panier", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(commander|achetez)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "€\\s*[0-9]", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "prix\\s+à\\s+partir", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(tarif|promotion)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(définition|glossaire|encyclopédie)\\b", "flags": "i", "reason": "Reference = R4" }
    ],
    "R3_conseils": [
      { "pattern": "ajouter\\s+au\\s+panier", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(commander|achetez)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "€\\s*[0-9]", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "prix\\s+à\\s+partir", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(tarif|promotion)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(définition|glossaire|encyclopédie)\\b", "flags": "i", "reason": "Reference = R4" }
    ],
    "R4": [
      { "pattern": "étape\\s+[0-9]", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "\\b(pas[\\s-]à[\\s-]pas)\\b", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "\\b(tutoriel|tuto|comment\\s+remplacer)\\b", "flags": "i", "reason": "Procedure = R3" },
      { "pattern": "ajouter\\s+au\\s+panier", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(achetez|commander)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "€\\s*[0-9]", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "\\b(prix|tarif|promotion)\\b", "flags": "i", "reason": "Transactionnel = R1" },
      { "pattern": "compatible\\s+avec\\s+votre\\s+véhicule", "flags": "i", "reason": "Transactionnel = R1" }
    ]
  }
