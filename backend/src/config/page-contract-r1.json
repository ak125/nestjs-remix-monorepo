{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.automecanik.com/schemas/PageContractR1.json",
  "title": "PageContractR1",
  "type": "object",
  "properties": {
    "page_role": {
      "type": "string",
      "const": "R1_ROUTER"
    },
    "primary_intent": {
      "type": "string",
      "minLength": 20,
      "maxLength": 220
    },
    "allowed_subintents": {
      "minItems": 3,
      "maxItems": 6,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "compatibility_checks",
          "mounting_variants",
          "identifier_check",
          "exchange_standard",
          "consigne",
          "delivery_returns_support"
        ]
      }
    },
    "forbidden_topics": {
      "minItems": 12,
      "maxItems": 24,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_lexicon": {
      "minItems": 12,
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_lexicon": {
      "minItems": 25,
      "maxItems": 35,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confusion_pairs": {
      "minItems": 0,
      "maxItems": 10,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60
          },
          "confused_with": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60
          },
          "distinction": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          }
        },
        "required": [
          "term",
          "confused_with",
          "distinction"
        ],
        "additionalProperties": false
      }
    },
    "writing_constraints": {
      "type": "object",
      "properties": {
        "max_words": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "min_words": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "tone": {
          "type": "string",
          "minLength": 3,
          "maxLength": 40
        },
        "person": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20
        },
        "zero_diagnostic": {
          "type": "boolean"
        },
        "zero_howto": {
          "type": "boolean"
        }
      },
      "required": [
        "max_words",
        "min_words",
        "tone",
        "person",
        "zero_diagnostic",
        "zero_howto"
      ],
      "additionalProperties": false
    },
    "interest_nuggets": {
      "minItems": 3,
      "maxItems": 3,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "angle": {
            "type": "string",
            "minLength": 5,
            "maxLength": 80
          },
          "hook": {
            "type": "string",
            "minLength": 10,
            "maxLength": 120
          },
          "rag_source": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200
          }
        },
        "required": [
          "angle",
          "hook",
          "rag_source"
        ],
        "additionalProperties": false
      }
    },
    "table_rows_library": {
      "minItems": 8,
      "maxItems": 8,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "element": {
            "type": "string",
            "enum": [
              "Référence / équivalence",
              "Connectique",
              "Dimensions",
              "Fixations",
              "Norme / homologation",
              "Échange standard",
              "Consigne",
              "Identifiant"
            ]
          },
          "how_to_check": {
            "type": "string",
            "minLength": 20,
            "maxLength": 180
          }
        },
        "required": [
          "element",
          "how_to_check"
        ],
        "additionalProperties": false
      }
    },
    "safe_table_plan": {
      "minItems": 4,
      "maxItems": 6,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "element": {
            "type": "string",
            "enum": [
              "Référence / équivalence",
              "Connectique",
              "Dimensions",
              "Fixations",
              "Norme / homologation",
              "Échange standard",
              "Consigne",
              "Identifiant"
            ]
          },
          "how_to_check": {
            "type": "string",
            "minLength": 20,
            "maxLength": 180
          }
        },
        "required": [
          "element",
          "how_to_check"
        ],
        "additionalProperties": false
      }
    },
    "visual_plan": {
      "type": "object",
      "properties": {
        "hero_wallpaper": {
          "type": "string",
          "const": "none"
        },
        "selector_category_image": {
          "type": "string",
          "const": "required"
        },
        "compatibilities_cards": {
          "type": "string",
          "const": "icons_only"
        },
        "compatibilities_label_rule": {
          "type": "string",
          "const": "label_1_2_words_required"
        },
        "equipementiers": {
          "type": "string",
          "const": "logo_strip"
        },
        "cross_sell": {
          "type": "string",
          "const": "icon_grid"
        },
        "cross_sell_rules": {
          "type": "object",
          "properties": {
            "max_items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 6
            },
            "same_family_only": {
              "type": "boolean",
              "const": true
            }
          },
          "required": [
            "max_items",
            "same_family_only"
          ],
          "additionalProperties": false
        },
        "sticky_mobile_cta": {
          "type": "string",
          "const": "enabled"
        },
        "hero_primary_cta": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "minLength": 6,
              "maxLength": 48
            },
            "action": {
              "type": "string",
              "const": "use_vehicle_selector"
            }
          },
          "required": [
            "label",
            "action"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "hero_wallpaper",
        "selector_category_image",
        "compatibilities_cards",
        "compatibilities_label_rule",
        "equipementiers",
        "cross_sell",
        "cross_sell_rules",
        "sticky_mobile_cta",
        "hero_primary_cta"
      ],
      "additionalProperties": false
    },
    "content_contract": {
      "type": "object",
      "properties": {
        "total_words_target": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          ]
        },
        "micro_seo_words_target": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          ]
        },
        "faq_answer_words_target": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          ]
        },
        "max_gamme_mentions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "max_compatible_mentions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      },
      "required": [
        "total_words_target",
        "micro_seo_words_target",
        "faq_answer_words_target",
        "max_gamme_mentions",
        "max_compatible_mentions"
      ],
      "additionalProperties": false
    },
    "hard_rules": {
      "type": "object",
      "properties": {
        "ban_howto_markers": {
          "minItems": 6,
          "maxItems": 30,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ban_absolute_claims": {
          "minItems": 3,
          "maxItems": 20,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ban_price_push": {
          "minItems": 3,
          "maxItems": 20,
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ban_howto_markers",
        "ban_absolute_claims",
        "ban_price_push"
      ],
      "additionalProperties": false
    },
    "media_slots": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "object",
          "properties": {
            "no_wallpaper": {
              "type": "boolean",
              "const": true
            },
            "selector_category_image_required": {
              "type": "boolean",
              "const": true
            },
            "logos_must_be_official_or_internal": {
              "type": "boolean",
              "const": true
            },
            "compat_icons_only": {
              "type": "boolean",
              "const": true
            },
            "cross_sell_icons_only": {
              "type": "boolean",
              "const": true
            },
            "no_vehicle_photos": {
              "type": "boolean",
              "const": true
            },
            "alt_style": {
              "type": "string",
              "const": "descriptive_no_hype_no_price"
            }
          },
          "required": [
            "no_wallpaper",
            "selector_category_image_required",
            "logos_must_be_official_or_internal",
            "compat_icons_only",
            "cross_sell_icons_only",
            "no_vehicle_photos",
            "alt_style"
          ],
          "additionalProperties": false
        },
        "slots": {
          "minItems": 4,
          "maxItems": 6,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slot": {
                "type": "string",
                "enum": [
                  "selector_category_image",
                  "equipementiers_logo_strip",
                  "cross_sell_icons",
                  "og_image",
                  "breadcrumb_icon",
                  "empty_state_icon"
                ]
              },
              "type": {
                "type": "string",
                "enum": [
                  "image",
                  "logo",
                  "icon"
                ]
              },
              "required": {
                "type": "boolean"
              },
              "usage": {
                "type": "string",
                "minLength": 10,
                "maxLength": 180
              },
              "asset_id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "fallback": {
                "maxItems": 4,
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "constraints": {
                "type": "object",
                "properties": {
                  "no_vehicle": {
                    "type": "boolean"
                  },
                  "no_text_overlay": {
                    "type": "boolean"
                  },
                  "formats": {
                    "minItems": 1,
                    "maxItems": 4,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "1:1",
                        "4:3",
                        "1200x630",
                        "svg"
                      ]
                    }
                  },
                  "crop": {
                    "type": "string",
                    "enum": [
                      "center",
                      "contain"
                    ]
                  },
                  "background": {
                    "type": "string",
                    "enum": [
                      "transparent",
                      "neutral"
                    ]
                  }
                },
                "required": [
                  "no_vehicle",
                  "no_text_overlay",
                  "formats",
                  "crop",
                  "background"
                ],
                "additionalProperties": false
              },
              "alt_template": {
                "type": "string",
                "minLength": 2,
                "maxLength": 120
              }
            },
            "required": [
              "slot",
              "type",
              "required",
              "usage",
              "constraints",
              "alt_template"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "rules",
        "slots"
      ],
      "additionalProperties": false
    },
    "hero_cta_helper_line": {
      "type": "string",
      "minLength": 10,
      "maxLength": 180
    }
  },
  "required": [
    "page_role",
    "primary_intent",
    "allowed_subintents",
    "forbidden_topics",
    "allowed_lexicon",
    "forbidden_lexicon",
    "confusion_pairs",
    "writing_constraints",
    "interest_nuggets",
    "table_rows_library",
    "safe_table_plan",
    "visual_plan",
    "content_contract",
    "hard_rules",
    "media_slots",
    "hero_cta_helper_line"
  ],
  "additionalProperties": false
}