# Configuration Cyberplus/SystemPay BNP Paribas
# 🔐 Valeurs réelles à fournir via vault — copiez ce template vers .env.cyberplus (gitignored).
CYBERPLUS_SITE_ID=<your-cyberplus-site-id>
CYBERPLUS_CERTIFICAT=<rotate-via-systempay-portal>
CYBERPLUS_MODE=TEST
CYBERPLUS_PAYMENT_URL=https://secure.systempay.fr/vads-payment/

# URL de base de l'application
APP_URL=http://localhost:3000

# Configuration Supabase (format moderne 2025)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<rotate-via-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<rotate-via-supabase-dashboard>
