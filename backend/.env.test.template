# ===============================================
# DATABASE CONFIGURATION - SUPABASE REST API
# ===============================================
# ✅ Nous utilisons uniquement l'API REST Supabase
# ❌ Pas de connexion PostgreSQL directe (DATABASE_URL supprimé)
# ✅ Tous les services héritent de SupabaseBaseService
#
# 🔐 SECRETS : copiez ce fichier vers `.env.test` (gitignored) et remplissez
# les valeurs depuis le vault. AUCUN secret réel ne doit vivre ici (template
# commit dans repo public — cf. PR sanitization 2026-05-19).
# Format moderne Supabase 2025 :
#   - publishable : sb_publishable_<22-char-random>_<8-char-checksum>
#   - secret      : sb_secret_<22-char-random>_<8-char-checksum>
# Legacy JWT (eyJ…) désactivé Supabase-side, ne pas utiliser.

SUPABASE_URL="https://cxpojprgwgubzjyqzmoq.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_<rotate-via-supabase-dashboard>"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_<rotate-via-supabase-dashboard>"

REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
# Générer une nouvelle valeur via : openssl rand -hex 32
SESSION_SECRET="<generate-via-openssl-rand-hex-32>"

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER="google"
ANALYTICS_GOOGLE_ID="GA_MEASUREMENT_ID_TEST"

# ===============================================
# EMAIL SERVICE - RESEND
# ===============================================
# Obtenir votre clé sur https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY="re_<your-resend-api-key>"
EMAIL_FROM="onboarding@resend.dev"
APP_URL="http://localhost:5173"

# ===============================================
# TEST & DEVELOPMENT ONLY
# ===============================================
# Credentials pour le endpoint /auth/debug-users (dev/test uniquement)
# ⚠️ CES VARIABLES NE DOIVENT JAMAIS ÊTRE UTILISÉES EN PRODUCTION
TEST_USER_EMAIL="<test-user-email>"
TEST_USER_PASSWORD="<test-user-password-non-prod>"

SITEMAP_URL=https://automecanik.fr/sitemap.xml

# ===============================================
# PAYMENT GATEWAY - SystemPay/Lyra (BNP Paribas)
# ===============================================
# Documentation: https://paiement.systempay.fr/doc/
# ⚠️  IMPORTANT : Utilisez des credentials différents pour TEST et PRODUCTION
# 🔐 Rotation : SystemPay portal → API keys → regenerate (vendor-side action).

# Identifiant du site marchand (SITE_ID = non-secret, OK en clair en interne)
SYSTEMPAY_SITE_ID="<systempay-site-id>"

# Certificats (clés secrètes - NE JAMAIS LOGGER)
SYSTEMPAY_CERTIFICATE_PROD="<systempay-cert-prod-from-vault>"
SYSTEMPAY_CERTIFICATE_TEST="<systempay-cert-test-from-vault>"

# Mode: PRODUCTION ou TEST
SYSTEMPAY_MODE=TEST

# URL du gateway de paiement
SYSTEMPAY_API_URL=https://paiement.systempay.fr/vads-payment/

# Base URL for payment callbacks
BASE_URL="https://www.automecanik.com"

# Méthode de signature SystemPay (HMAC = DSP2 canon, SHA1 = legacy)
SYSTEMPAY_SIGNATURE_METHOD=HMAC

# Clés HMAC SystemPay
SYSTEMPAY_HMAC_KEY_TEST="<systempay-hmac-test-from-vault>"
SYSTEMPAY_HMAC_KEY_PROD="<systempay-hmac-prod-from-vault>"

# ===============================================
# PAYBOX/VERIFONE
# ===============================================
# Documentation: https://www1.paybox.com/espace-integrateur-documentation/
# 🔐 Rotation : Paybox portal → identifiants → regenerate (vendor-side action).

PAYBOX_SITE="<paybox-site-from-vault>"
PAYBOX_RANG="<paybox-rang-from-vault>"
PAYBOX_IDENTIFIANT="<paybox-identifiant-from-vault>"

# Clé HMAC pour signature (HMAC-SHA512)
PAYBOX_HMAC_KEY="<paybox-hmac-from-vault>"

# URL de paiement
PAYBOX_URL=https://tpeweb.paybox.com/cgi/MYchoix_pagepaiement.cgi

# Devise (978 = EUR)
PAYBOX_DEVISE=978

# PAYBOX MODE
PAYBOX_MODE=TEST
PAYBOX_PAYMENT_URL=https://preprod-tpeweb.paybox.com/cgi/MYchoix_pagepaiement.cgi
