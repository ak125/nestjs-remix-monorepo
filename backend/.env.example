# ===============================================
# AUTOMECANIK - PRODUCTION ENVIRONMENT TEMPLATE
# ===============================================
# Copier ce fichier en .env et remplir les valeurs
# ⚠️ NE JAMAIS COMMITER .env avec des valeurs réelles

# ===============================================
# REQUIRED - L'application ne démarre pas sans ces variables
# ===============================================
NODE_ENV=production

# Supabase (Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Sessions)
REDIS_URL=redis://redis_prod:6379
REDIS_HOST=redis_prod
REDIS_PORT=6379
SESSION_SECRET=generate-a-64-char-random-string

# Login lockout threshold (ADR-043 Sprint 1 ticket #8)
# Failed login attempts before account is temporarily locked (15 min window).
# Conservative default = 5. Tighten in prod if needed (e.g., 3).
LOGIN_LOCKOUT_MAX_ATTEMPTS=5

# Payment - SystemPay (BNP Paribas)
SYSTEMPAY_SITE_ID=your-site-id
SYSTEMPAY_CERTIFICATE_PROD=your-certificate
SYSTEMPAY_MODE=PRODUCTION

# Payment - Paybox (Verifone)
PAYBOX_SITE=your-site
PAYBOX_RANG=001
PAYBOX_IDENTIFIANT=your-identifiant
PAYBOX_HMAC_KEY=your-hmac-key
PAYBOX_MODE=PRODUCTION

# ===============================================
# OPTIONAL - Valeurs par défaut utilisées si absentes
# ===============================================

# Base URLs
APP_URL=https://www.automecanik.com
BASE_URL=https://www.automecanik.com

# Supabase Direct Connection (for migrations)
SUPABASE_DB_HOST=aws-0-eu-central-1.pooler.supabase.com
SUPABASE_DB_PASSWORD=

# Email Service (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@automecanik.com

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=google
ANALYTICS_GOOGLE_ID=

# SystemPay Additional
SYSTEMPAY_API_URL=https://paiement.systempay.fr/vads-payment/
# Signature method: HMAC (DSP2 canon, HMAC-SHA-256) or SHA1 (legacy CGI, deprecated)
SYSTEMPAY_SIGNATURE_METHOD=HMAC
SYSTEMPAY_CERTIFICATE_TEST=
SYSTEMPAY_HMAC_KEY_TEST=
SYSTEMPAY_HMAC_KEY_PROD=

# Paybox Additional
PAYBOX_PAYMENT_URL=https://tpeweb.paybox.com/cgi/MYchoix_pagepaiement.cgi
PAYBOX_DEVISE=978
PAYBOX_CALLBACK_MODE=strict

# AI Content Generation — Anthropic seul (skills-first architecture)
# Default model is defined in backend/src/modules/ai-content/config/models.constants.ts
# Override only if you need a specific pinned version (e.g. regression isolation).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Advisor escalation (Pattern A — documented subagent fallback).
# Executor produces a draft; if the caller's gate decides the draft is
# insufficient, the advisor model produces an improved version.
# Only consumed by callers that opt into generateContentWithAdvisor().
# ANTHROPIC_ADVISOR_MODEL=claude-opus-4-6

# RAG PDF Classifier (PdfRagClassifierService) — Groq direct, independant de AiContentService
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Performance
VEHICLES_CACHE_TTL=3600
REDIS_CACHE_TTL=604800
ENABLE_RPC_V2=true
USE_UNIFIED_RPC=true
USE_SEPARATE_OEM_RPC=true

# RAG Service (optional - set to disabled if not used)
RAG_SERVICE_URL=http://disabled:8000
RAG_API_KEY=disabled
RAG_KNOWLEDGE_PATH=/opt/automecanik/rag/knowledge

# Read Model (RM) - Optimisation Catalogue
USE_RM_API=false

# Google Ads API (optional)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Gmail API (optional)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ENCRYPTION_KEY=
GMAIL_USER_EMAIL=

# ============================================
# SEO Department - Observability (Phase 1)
# ============================================
# Setup procedure: .spec/runbooks/seo/observability-setup.md
# Note : conventions GSC_* / GA4_* déjà câblées dans crawl-budget-audit.service.ts
# et url-audit.service.ts. Réutilisation de l'existant, pas de nouvelle convention.

# Google Search Console (Service Account credentials)
# Le même SA peut servir GSC + GA4 (les paires sont séparées par convention codebase)
GSC_CLIENT_EMAIL=
# private_key avec "\n" littéraux (cf. runbook §4)
GSC_PRIVATE_KEY=
# Propriété GSC à monitorer (domaine production)
GSC_SITE_URL=https://www.automecanik.com

# Google Analytics 4 (Service Account credentials)
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=
# Property ID GA4 numérique (Admin → Property details)
GA4_PROPERTY_ID=

# Kill-switch global pour fetchers SEO (set false pour bypass crons)
SEO_MONITORING_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# SEO Production Control Plane (ADR-064) — L1 Synthetic Crawler PR-2A-1
# Sampling pondéré par criticality tier (seo-criticality.yaml). UA identifiable
# AutoMecanikSyntheticBot/1.0 (jamais spoof Googlebot, cf. canon mémoire).
# Queue BullMQ dédiée seo-crawler-monitor (séparée de seo-monitor).
# ─────────────────────────────────────────────────────────────────────────────
SEO_CP_SYNTHETIC_ENABLED=true
SEO_CP_SYNTHETIC_CRON=*/15 * * * *
SEO_CP_SAMPLE_SIZE=500
SEO_CP_CONCURRENCY=10
SEO_CP_TIMEOUT_MS=15000
SEO_CP_PROD_BASE=https://www.automecanik.com

# PR-2A-2 — L1 Cloudflare Analytics Collector (q5min GraphQL ingest)
# Réutilise CLOUDFLARE_API_TOKEN + CLOUDFLARE_ZONE_ID déjà câblés pour
# scripts/ops/cloudflare-purge-by-pattern.sh. Si l'un manque, le collector
# log un warning et skip le run (graceful, pas d'erreur runtime).
SEO_CP_CF_ANALYTICS_ENABLED=true
SEO_CP_CF_ANALYTICS_CRON=*/5 * * * *
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# L1 Runtime Logs Collector (PR-2A-3) — Source A du SLO multi-source.
# Scan __error_logs LOADER_* sur fenêtre glissante 60min, agrège par bucket
# 5-min × tier dans __seo_snapshot_runtime_logs (UPSERT idempotent).
# Mutualise la queue seo-crawler-monitor avec synthetic-crawler.
# ─────────────────────────────────────────────────────────────────────────────
SEO_CP_RUNTIME_LOGS_ENABLED=true
SEO_CP_RUNTIME_LOGS_CRON=*/5 * * * *

# Email recipient pour alertes SEO (utilise infra nodemailer existante)
SEO_ALERTS_EMAIL_TO=
# Seuils alertes (defaults : -20% positions, -30% sessions sur 7j)
SEO_ALERTS_THRESHOLD_POSITION_PCT=20
SEO_ALERTS_THRESHOLD_TRAFFIC_PCT=30

# Chrome UX Report (CrUX) API key — ADR-063 (Accepted 2026-05-14)
# Scope : Chrome UX Report API in Google Cloud Console.
# Quota gratuit : 150 RPM. V1 consomme ~102 calls/jour (< 1 RPM moyen).
# Endpoint utilisé : POST /v1/records:queryHistoryRecord
# Récupération : https://console.cloud.google.com/apis/credentials → API key avec
# restriction "Chrome UX Report API" uniquement. Backend-only (jamais exposée frontend).
CRUX_API_KEY=


# ============================================
# Observability - Sentry (Error monitoring)
# ============================================
# Setup: docs/runbooks/sentry-vps-setup.md
# Secrets: managed via SOPS in secrets/sentry.dev.sops.env
# (decrypted at deploy time by scripts/secrets/run-with-secrets.sh)

# Sentry DSN backend (NestJS) — REQUIRED to enable error reporting.
# When unset, the SDK is a no-op (zero overhead).
SENTRY_DSN=

# Sentry DSN frontend (Remix) — exposed to browser via window.ENV.
# DSN is publicly visible by design; not a secret in the conventional sense.
VITE_SENTRY_DSN=

# Auth token for sentry-cli (release/source-map upload, signal A queries).
# Used only on the VPS by post-deploy hook + cron, never sent to the runtime.
SENTRY_AUTH_TOKEN=

# Sentry org + project slugs (used by sentry-cli)
SENTRY_ORG=auto-pieces-equipement
SENTRY_PROJECT_BACKEND=automecanik-backend-dev
SENTRY_PROJECT_FRONTEND=automecanik-frontend-dev

# Environment label visible in Sentry UI ("dev", "preprod", "production")
# Defaults to APP_ENV → NODE_ENV if unset.
SENTRY_ENVIRONMENT=dev

# 0..1 — fraction of transactions sampled for performance monitoring.
# 0.1 = 10%. Lower in production if quota becomes an issue.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Set to "true" to opt-in to default PII collection (IP, cookies). Defaults
# to false for RGPD minimisation. Enable only if user-impact debugging requires it.
SENTRY_SEND_PII=false

# Set to "true" to expose /health/sentry-debug in production for one-shot
# verification after a deploy. Disable immediately after smoke test.
SENTRY_ALLOW_DEBUG_ENDPOINT=false

# Optional: explicit release tag. Defaults to GIT_SHA at deploy time.
# SENTRY_RELEASE=

# ────────────────────────────────────────────────────────────────────────
# SEO Governance Control Plane (PR-C — OPA Write Gateway)
# ────────────────────────────────────────────────────────────────────────
#
# OPA_BUNDLE_MODE — selects the source for the H1 write policy bundle.
#   prod_vault          : reads OPA_BUNDLE_PATH (vault mirror sync). DEV preprod + PROD.
#   dev_fixture         : reads backend/test/fixtures/opa-policies/seo-content/h1-write.wasm
#                         (committed snapshot, SHA-matched to vault). Local pnpm dev.
#   test_fixture        : same path as dev_fixture, deterministic for CI tests.
#   missing_fail_closed : EXPLICIT default if unset — denies every H1 write.
#                         Set this explicitly if you want fail-closed without a bundle.
#
# Absence of OPA_BUNDLE_MODE = fail-closed deny (NOT permit-all).
# Memory : feedback_check_secret_propagation_when_adding_fail_fast
OPA_BUNDLE_MODE=dev_fixture

# OPA_BUNDLE_PATH — only used when OPA_BUNDLE_MODE=prod_vault. Absolute path
# to the WASM bundle synced from governance-vault dist/policies/.
# Example: /opt/automecanik/governance-vault-mirror/dist/policies/h1-write.wasm
# OPA_BUNDLE_PATH=

# ────────────────────────────────────────────────────────────────────────
# SEO Governance — PR-E+1 Recovery Rollout (GrowthBook + BullMQ + GSC)
# ────────────────────────────────────────────────────────────────────────

# GrowthBook SDK : primary source for recovery flags. If unset, the rollout
# gate falls back to SEO_H1_RECOVERY_ENABLED / SEO_H1_RECOVERY_ROLLOUT_PCT
# env vars (dev/CI mode). Production should use GrowthBook for live flag mgmt.
# GROWTHBOOK_CLIENT_KEY=
GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# Env fallback for the rollout gate (used only if GROWTHBOOK_CLIENT_KEY is unset).
# Kill-switch : if false, no recovery write happens, period.
SEO_H1_RECOVERY_ENABLED=false
# % of assets eligible (deterministic hash bucket). 0 = nothing rolls out.
SEO_H1_RECOVERY_ROLLOUT_PCT=0

# BullMQ scheduler (PR-E+1). Disable to prevent the repeatable job from being
# registered at all. Keeping it enabled is SAFE because the worker is a no-op
# until SEO_H1_RECOVERY_ENABLED=true (or GrowthBook flag is on).
SEO_H1_RECOVERY_SCHEDULER_ENABLED=true
SEO_H1_RECOVERY_CRON=*/5 * * * *
SEO_H1_RECOVERY_BATCH_SIZE=10
# 7 days * 24h * 60min = 10080. Window for scanning unprocessed proposed events.
SEO_H1_RECOVERY_SINCE_MINUTES=10080

# Multi-source validator (PR-E+1). UA identifiable, never spoof Googlebot.
SEO_RECOVERY_VALIDATOR_UA=AutoMecanikRecoveryValidator/1.0 (+https://www.automecanik.com/about/seo)
SEO_RECOVERY_VALIDATOR_TIMEOUT_MS=15000
# GSC J+7 secondary alert : warn if impressions Δ% < -SEO_GSC_DELTA_ALERT_PCT.
SEO_GSC_DELTA_ALERT_PCT=10
