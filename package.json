{
  "name": "nestjs-remix-monorepo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "turbo test",
    "dev": "turbo dev",
    "dev:core": "echo '🚀 DEV CORE - Modules essentiels uniquement' && turbo dev --filter=@fafa/backend --filter=@fafa/frontend",
    "dev:full:all": "echo '🔧 DEV FULL - Cockpit complet + workers' && turbo dev",
    "lint": "turbo lint",
    "build": "turbo build",
    "size": "npm run -w @fafa/frontend size",
    "typecheck": "turbo typecheck",
    "start": "cd backend && npm run start",
    "clean-node-modules": "find . -type d -name 'node_modules' -exec rm -rf {} + && find . -name 'package-lock.json' -exec rm -f {} +",
    "clean-turbo-cache": "find . -name '.turbo' -type d -exec rm -rf {} +",
    "dev:clean": "pkill -f 'tsc --build --watch' ; pkill -f 'tsc --watch' ; pkill -f 'tsup --watch' ; pkill -f turbo ; echo 'Dev processes cleaned'",
    "pipeline:full": "node scripts/mcp-orchestrator.js",
    "migrate:auto": "node scripts/auto-migrate.js",
    "audit:full": "node ../audit-migration-exhaustif.js",
    "sql:lint": "node node_modules/squawk-cli/js/bin/squawk --config .squawk.toml 'backend/supabase/migrations/**/*.sql'",
    "sql:lint:check": "node node_modules/squawk-cli/js/bin/squawk --version",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "spec:validate": "turbo spec:validate && bash scripts/validate-specs.sh",
    "spec:generate": "turbo spec:generate && bash scripts/generate-specs.sh",
    "spec:report": "turbo spec:report && bash scripts/spec-report.sh",
    "docs:install": "cd .spec/docs && npm install",
    "docs:dev": "cd .spec/docs && npm start",
    "docs:build": "cd .spec/docs && npm run build",
    "dev:full": "echo '⚠️ Lancer dans 2 terminaux: 1) npm run dev (backend+frontend port 3000), 2) npm run docs:dev (portail port 3002)'",
    "prepare": "husky",
    "check:no-client-localhost": "bash scripts/check-no-client-localhost.sh",
    "audit:knip": "knip --no-exit-code --reporter compact",
    "audit:madge": "madge --circular --extensions ts,tsx backend/src frontend/app",
    "audit:depcruise": "depcruise --config .dependency-cruiser.cjs --output-type err-long backend/src frontend/app",
    "audit:ast": "ast-grep scan",
    "audit:graph": "madge --json --extensions ts,tsx backend/src frontend/app > audit-reports/dep-graph.json",
    "vlevel:v3:decision-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts decision-pack",
    "vlevel:v3:decontaminate-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts decontaminate-pack",
    "vlevel:v3:reelection-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts reelection-pack",
    "vlevel:auto:plan": "tsx scripts/seo/vlevel-v3-pipeline.ts auto-plan",
    "vlevel:blocked:plan": "tsx scripts/seo/vlevel-v3-pipeline.ts blocked-plan",
    "vlevel:blocked:apply-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts blocked-apply-pack",
    "vlevel:v3:generics-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts generics-pack",
    "vlevel:v3:validate-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts validate-pack",
    "vlevel:v3:apply-pack": "tsx scripts/seo/vlevel-v3-pipeline.ts apply-pack",
    "audit:baseline": "node scripts/cleanup/audit-compare-baseline.js",
    "audit:baseline:json": "node scripts/cleanup/audit-compare-baseline.js --json",
    "audit:baseline:strict": "node scripts/cleanup/audit-compare-baseline.js --strict",
    "audit:baseline:refresh": "node scripts/cleanup/audit-compare-baseline.js --refresh",
    "audit:all": "npm run audit:ast && npm run audit:madge && npm run audit:depcruise && npm run audit:knip",
    "audit:seo-matrix": "tsx scripts/seo/dump-agent-matrix.ts",
    "audit:seo-matrix:check": "npm run audit:seo-matrix && git diff --exit-code -- audit-reports/seo-agent-matrix.json",
    "audit:drift-dashboard": "tsx scripts/audit/build-drift-dashboard.ts",
    "audit:drift-dashboard:check": "tsx --test scripts/audit/build-drift-dashboard.test.ts",
    "audit:cleanup-candidates": "tsx scripts/audit/build-cleanup-candidates.ts",
    "audit:cleanup-candidates:check": "tsx scripts/audit/build-cleanup-candidates.ts --check",
    "audit:contract-drift-ratchet": "tsx scripts/audit/check-contract-drift-ratchet.ts",
    "audit:contract-drift-ratchet:json": "tsx scripts/audit/check-contract-drift-ratchet.ts --json",
    "audit:contract-drift-ratchet:refresh": "tsx scripts/audit/check-contract-drift-ratchet.ts --refresh",
    "audit:contract-drift-ratchet:test": "tsx --test scripts/audit/check-contract-drift-ratchet.test.ts",
    "audit:dependency-graph-ratchet": "tsx scripts/audit/check-dependency-graph-ratchet.ts",
    "audit:dependency-graph-ratchet:refresh": "tsx scripts/audit/check-dependency-graph-ratchet.ts --refresh",
    "audit:dependency-graph-ratchet:test": "tsx --test scripts/audit/check-dependency-graph-ratchet.test.ts",
    "audit:pr-9-modernization-inventory": "tsx scripts/audit/build-dependency-modernization-inventory.ts",
    "audit:pr-9-modernization-inventory:check": "tsx scripts/audit/build-dependency-modernization-inventory.ts --check",
    "deps:bump-family": "node scripts/audit/bump-dependency-family.mjs",
    "deps:check-scope": "bash scripts/governance/check-family-pr-scope.sh",
    "audit:db-usage": "node scripts/audit/build-db-usage-map.js",
    "audit:inventory": "node scripts/audit/build-deep-inventory.js && node scripts/audit/build-db-usage-map.js",
    "audit:inventory:check": "npm run audit:inventory && git diff --exit-code -- audit/*.json",
    "registry:build:files": "node scripts/registry/build-files-registry.js",
    "registry:build:runtime": "node scripts/registry/build-runtime-registry.js",
    "registry:build:deps": "node scripts/registry/build-deps-registry.js",
    "registry:build:db": "node scripts/registry/build-db-registry.js",
    "registry:build:rpc": "node scripts/registry/build-rpc-registry.js",
    "registry:build": "npm run registry:build:files && npm run registry:build:runtime && npm run registry:build:deps && npm run registry:build:db && npm run registry:build:rpc",
    "registry:build:planning": "node scripts/registry/build-planning-registry.js",
    "registry:build:dependency-graph": "node scripts/registry/build-dependency-graph.js",
    "registry:build:automation": "node scripts/audit/build-automation-inventory.js",
    "registry:validate:automation": "tsx scripts/registry/validate-automation-overlay.ts",
    "registry:test:rpc-parser": "tsx --test tests/registry/rpc-parser.test.ts",
    "registry:test:invariants": "tsx --test scripts/registry/validate-invariants.test.ts",
    "registry:test:files-reachability": "tsx --test scripts/registry/build-files-registry.test.ts",
    "registry:test:planning": "tsx --test tests/registry/planning-builder.test.ts",
    "registry:test:dependency-graph": "tsx --test tests/registry/dependency-graph-builder.test.ts",
    "registry:validate:zod": "tsx scripts/registry/validate-zod-schemas.ts",
    "registry:seed-ownership": "node scripts/registry/seed-ownership.js --write",
    "registry:validate": "tsx scripts/registry/validate-overlay.ts",
    "registry:build:canonical": "node scripts/registry/build-canonical-registry.js",
    "registry:build:llm-map": "node scripts/registry/build-llm-repo-map.js",
    "registry": "npm run registry:build && npm run registry:build:canonical && npm run registry:build:llm-map",
    "registry:validate-invariants": "tsx scripts/registry/validate-invariants.ts",
    "registry:check-new-files": "node scripts/registry/check-new-files.js",
    "governance:command-center": "node scripts/governance/build-command-center-snapshot.js",
    "governance:command-center:check": "node scripts/governance/build-command-center-snapshot.js --check",
    "governance:test:command-center": "tsx --test scripts/governance/__tests__/build-command-center-snapshot.test.ts",
    "content:raw-evidence:schema-check": "tsx scripts/wiki-generators/raw-evidence-inventory.ts --check",
    "content:test:raw-evidence": "tsx --test scripts/wiki-generators/__tests__/raw-evidence-inventory.test.ts",
    "architecture:build": "npm -w @repo/registry run build:architecture",
    "architecture:test": "tsx --test tests/registry/architecture-generator.test.ts",
    "depcruise:integrity-test": "tsx --test tests/registry/depcruise-integrity.test.ts",
    "db-contract:build": "npm -w @repo/registry run build:db-contract",
    "runtime-contract:build": "npm -w @repo/registry run build:runtime-contract",
    "dep-governance:build": "npm -w @repo/registry run build:dep-governance",
    "rpc-contract:build": "npm -w @repo/registry run build:rpc-contract"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "description": "",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "devDependencies": {
    "@ast-grep/cli": "0.44.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@react-router/dev": "^7.15.0",
    "@types/bcrypt": "^6.0.0",
    "@types/file-type": "^10.9.3",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/multer": "^2.1.0",
    "dependency-cruiser": "17.4.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fast-json-stable-stringify": "^2.1.0",
    "js-yaml": "^4.1.1",
    "knip": "6.17.1",
    "lint-staged": "^16.4.0",
    "madge": "8.0.0",
    "micromatch": "^4.0.8",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "squawk-cli": "2.58.0",
    "turbo": "^2.9.16",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@react-router/express": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "@repo/seo-roles": "*",
    "@supabase/supabase-js": "^2.95.0",
    "abort-controller": "^3.0.0",
    "autoprefixer": "^10.4.14",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "nestjs-zod": "^4.3.1",
    "node-fetch": "^3.3.2",
    "postcss": "^8.4.24",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^7.15.0",
    "remix-flat-routes": "^0.8.5",
    "sharp": "^0.34.3",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.15",
    "uid": "^2.0.2",
    "vite": "^5.4.11",
    "zod": "^3.25.76"
  },
  "overrides": {
    "@types/node": "^24",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "path-to-regexp": "3.3.0",
    "zod": "^3.25.76",
    "typescript": "6.0.3",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "8.61.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/utils": "8.61.1",
    "handlebars": "4.7.9",
    "knip": {
      "zod": "^4.0.0"
    }
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "node --max-old-space-size=4096 node_modules/.bin/eslint --cache --fix",
      "prettier --write"
    ]
  }
}
