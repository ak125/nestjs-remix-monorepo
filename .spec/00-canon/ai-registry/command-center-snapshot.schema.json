{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automecanik.com/canon/command-center-snapshot.schema.json",
  "title": "Command Center Snapshot (generated projection)",
  "description": "Deterministic structural projection of agent-operating-map.yaml for the admin Command Center hub. Generated by scripts/governance/build-command-center-snapshot.js — never edited by hand. Contains NO wall-clock/git fields (generated_at/git_sha/stale_status/global_status are added live by the backend reader).",
  "type": "object",
  "required": [
    "schema_version",
    "source_truth",
    "summary",
    "executive_kpis",
    "departments",
    "capabilities",
    "chains",
    "alerts",
    "owner_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "command-center.v1" },
    "source_truth": {
      "type": "object",
      "required": ["canon_path", "last_verified"],
      "additionalProperties": false,
      "properties": {
        "canon_path": { "type": "string", "minLength": 1 },
        "last_verified": { "type": ["string", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "departments_total",
        "by_priority",
        "by_state",
        "capabilities_total",
        "capabilities_certified",
        "capabilities_without_evidence",
        "handoffs_total",
        "handoffs_incomplete"
      ],
      "additionalProperties": false,
      "properties": {
        "departments_total": { "type": "integer", "minimum": 0 },
        "by_priority": {
          "type": "object",
          "required": ["P0", "P1", "P2", "P3"],
          "additionalProperties": false,
          "properties": {
            "P0": { "type": "integer", "minimum": 0 },
            "P1": { "type": "integer", "minimum": 0 },
            "P2": { "type": "integer", "minimum": 0 },
            "P3": { "type": "integer", "minimum": 0 }
          }
        },
        "by_state": {
          "type": "object",
          "required": ["live", "partial", "dormant", "broken", "duplicate"],
          "additionalProperties": false,
          "properties": {
            "live": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "dormant": { "type": "integer", "minimum": 0 },
            "broken": { "type": "integer", "minimum": 0 },
            "duplicate": { "type": "integer", "minimum": 0 }
          }
        },
        "capabilities_total": { "type": "integer", "minimum": 0 },
        "capabilities_certified": { "type": "integer", "minimum": 0 },
        "capabilities_without_evidence": { "type": "integer", "minimum": 0 },
        "handoffs_total": { "type": "integer", "minimum": 0 },
        "handoffs_incomplete": { "type": "integer", "minimum": 0 }
      }
    },
    "executive_kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "value", "status", "source", "certified"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "value": { "type": ["number", "string", "null"] },
          "unit": { "type": "string" },
          "status": { "enum": ["OK", "WARNING", "CRITICAL", "UNKNOWN"] },
          "source": { "enum": ["canon", "db", "gsc", "runtime", "audit", "manual"] },
          "certified": { "type": "boolean" }
        }
      }
    },
    "departments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "lead",
          "priority",
          "kpi_primary",
          "state",
          "family",
          "capabilities",
          "certification",
          "health_score_base",
          "structural_caps_applied"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "lead": { "type": "string", "minLength": 1 },
          "priority": { "type": ["string", "null"], "enum": ["P0", "P1", "P2", "P3", null] },
          "kpi_primary": { "type": ["string", "null"] },
          "state": { "enum": ["live", "partial", "dormant", "broken", "duplicate"] },
          "family": { "enum": ["Business", "Growth", "Operations", "AI-Governance"] },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "certification": { "enum": ["CERTIFIED", "PARTIAL", "UNKNOWN", "BROKEN"] },
          "health_score_base": { "type": "integer", "minimum": 0, "maximum": 100 },
          "structural_caps_applied": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "owner", "status", "certification", "reason", "module", "has_evidence", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["skill", "agent", "service", "module", "engine", "pipeline", "signal"] },
          "owner": { "type": "string" },
          "status": { "enum": ["live", "partial", "dormant", "broken", "duplicate"] },
          "certification": { "enum": ["CERTIFIED", "PARTIAL", "UNKNOWN", "BROKEN"] },
          "reason": { "type": ["string", "null"] },
          "module": { "type": ["string", "null"] },
          "has_evidence": { "type": "boolean" },
          "evidence": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "runtime": { "type": "string" },
              "adr": { "type": "string" },
              "scripts": { "type": "array", "items": { "type": "string" } },
              "tables": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "contract_ref", "contract_status", "gate", "state", "incomplete"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "contract_ref": { "type": ["string", "null"] },
          "contract_status": { "type": ["string", "null"], "enum": ["planned", "defined", null] },
          "gate": { "type": ["string", "null"] },
          "state": { "enum": ["EXISTS", "PARTIAL", "ASPIRATIONAL"] },
          "incomplete": { "type": "boolean" }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "target_kind", "target_id", "message"],
        "additionalProperties": false,
        "properties": {
          "code": { "enum": ["BROKEN_EVIDENCE", "OVERCLAIM_RISK", "P0_NO_KPI", "HANDOFF_INCOMPLETE"] },
          "severity": { "enum": ["error", "warn", "info"] },
          "target_kind": { "enum": ["capability", "department", "handoff", "map"] },
          "target_id": { "type": "string" },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "owner_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_alert", "target_id", "action", "owner", "file", "decision"],
        "additionalProperties": false,
        "properties": {
          "from_alert": { "enum": ["BROKEN_EVIDENCE", "OVERCLAIM_RISK", "P0_NO_KPI", "HANDOFF_INCOMPLETE"] },
          "target_id": { "type": "string" },
          "action": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
